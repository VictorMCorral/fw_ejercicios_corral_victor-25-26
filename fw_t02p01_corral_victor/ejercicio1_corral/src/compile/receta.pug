extends ../no_compile/layout.pug

block cabecera
    include ../no_compile/partials/cabecera.html

block content 
    main.main-content 
        .container.py-4 
            include ../no_compile/partials/usuario.html

            #recipe-container.mt-5.p-3 
                .row
                    .col-md-5
                        img#recipe-img.img-fluid.rounded.shadow(src="" alt="Imagen de la receta")
                    .col-md-5
                        h4 Categoría: 
                            span#recipe-category.badge.bg-primary
                        h4 Origen: 
                            span#recipe-area.badge.bg-secondary
                        h3.mt-4 Ingredientes
                        ul#recipe-ingredients.list-group.list-group-flush
                        button.btn.btn-outline-primary.w-100(type="button" id="btnGuardarReceta") Guardar
                        button.btn.btn-outline-danger.w-100.d-none(type="button" id="btnEliminarReceta") Eliminar

block scripts
    script(type="module" src="dist/app.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")